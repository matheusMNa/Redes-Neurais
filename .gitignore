#this gitignore was made with help of AI. It could be further revised, but each item
#is commented for maximum precision while reading the file.

# --- Jupyter Notebook Metadata ---
# Excludes the hidden directory where Jupyter saves periodic snapshots of your work
.ipynb_checkpoints/
# A wildcard rule ensuring that checkpoints in subdirectories (like Physics/ or Chemistry/) are also caught
*/.ipynb_checkpoints/*

# --- Python & Compiled Files ---
# Excludes the directory where Python stores "compiled" bytecode to speed up execution
__pycache__/
# Excludes individual compiled Python files
*.py[cod]
# Excludes compiled Python class files
*$py.class

# --- Virtual Environments ---
# If you ever create a local environment folder (e.g., via venv), these rules prevent 
# thousands of library files from being uploaded to GitHub
.env
.venv
env/
venv/
ENV/

# --- Computational Artifacts ---
# Excludes log files generated by simulations or system processes
*.log
# Excludes temporary files often created by editors or scripts
*.tmp
*.temp

# --- Binary & Large Data (Optional) ---
# Excludes NumPy binary files; usually better to keep large data out of Git 
# and use your environment.yml to regenerate them if needed
*.npy
*.npz
# Excludes MATLAB data files
*.mat
# Excludes Python "pickle" files (serialized objects)
*.pkl

# --- System-Specific Files ---
# Excludes macOS hidden metadata files
.DS_Store
# Excludes Windows thumbnail cache files
Thumbs.db


